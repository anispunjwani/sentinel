# Copy to .env for local dev, or set these in Replit Secrets.

# true  → app reads static JSON from public/mocks/ (demo mode, no backend needed)
# false → app calls the live FastAPI backend at VITE_API_URL with the stored JWT
VITE_USE_MOCKS=true

# Backend base URL. Only used when VITE_USE_MOCKS=false.
# Point this at your Railway domain when going live.
VITE_API_URL=http://localhost:8000